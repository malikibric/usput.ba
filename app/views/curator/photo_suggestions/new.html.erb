<div class="space-y-4 sm:space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.photo_suggestions.new_title") %></h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        <%= t("curator.photo_suggestions.for_location") %>:
        <%= link_to @location.name, curator_location_path(@location), class: "text-emerald-600 dark:text-emerald-400 hover:text-emerald-900 dark:hover:text-emerald-300" %>
      </p>
    </div>
    <%= link_to t("common.cancel"), curator_location_path(@location), class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200" %>
  </div>

  <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow">
    <div class="px-4 py-5 sm:px-6">
      <%= form_with model: @photo_suggestion, url: curator_location_photo_suggestions_path(@location), local: true, multipart: true do |f| %>
        <div class="space-y-6">
          <%# Photo upload option %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= t("curator.photo_suggestions.photo_source") %>
            </label>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <%# File upload - multiple %>
              <div data-controller="multi-photo-upload">
                <div data-multi-photo-upload-target="area" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-4 hover:border-emerald-500 dark:hover:border-emerald-400 transition-colors">
                  <label for="photo_suggestion_photos" class="block cursor-pointer">
                    <div data-multi-photo-upload-target="placeholder" class="text-center">
                      <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                      </svg>
                      <p class="mt-2 text-sm font-medium text-gray-900 dark:text-white"><%= t("curator.photo_suggestions.upload_photos", default: "Upload photos") %></p>
                      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= t("curator.photo_suggestions.upload_hint_multiple", default: "Select up to 10 images (max 10MB each)") %></p>
                    </div>
                    <%= f.file_field :photos, accept: "image/*", class: "sr-only", id: "photo_suggestion_photos",
                        multiple: true,
                        direct_upload: true,
                        data: { multi_photo_upload_target: "input", action: "change->multi-photo-upload#select" } %>
                  </label>

                  <%# Preview grid for multiple photos %>
                  <div data-multi-photo-upload-target="previewContainer" class="hidden mt-4">
                    <div class="flex items-center justify-between mb-2">
                      <span data-multi-photo-upload-target="count" class="text-sm text-gray-600 dark:text-gray-400"></span>
                      <button type="button" data-action="multi-photo-upload#clearAll" class="text-xs text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300">
                        <%= t("common.remove_all", default: "Remove all") %>
                      </button>
                    </div>
                    <div data-multi-photo-upload-target="previews" class="grid grid-cols-3 gap-2"></div>
                  </div>
                </div>
              </div>

              <%# URL input %>
              <div class="border-2 border-gray-300 dark:border-gray-600 rounded-lg p-4">
                <div class="text-center mb-4">
                  <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                  </svg>
                  <p class="mt-2 text-sm font-medium text-gray-900 dark:text-white"><%= t("curator.photo_suggestions.or_paste_url") %></p>
                </div>
                <%= f.text_field :photo_url,
                    placeholder: "https://example.com/photo.jpg",
                    class: "block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 dark:placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm" %>
              </div>
            </div>
          </div>

          <%# Description %>
          <div>
            <label for="photo_suggestion_description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              <%= t("curator.photo_suggestions.description") %>
              <span class="text-gray-400 dark:text-gray-500 font-normal">(<%= t("common.optional") %>)</span>
            </label>
            <%= f.text_area :description,
                rows: 3,
                placeholder: t("curator.photo_suggestions.description_hint"),
                class: "block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 placeholder:text-gray-400 dark:placeholder:text-gray-500 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm" %>
          </div>

          <%# Submit %>
          <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
            <%= link_to t("common.cancel"), curator_location_path(@location),
                class: "rounded-md bg-white dark:bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-white shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700" %>
            <%= f.submit t("curator.photo_suggestions.submit"),
                class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
