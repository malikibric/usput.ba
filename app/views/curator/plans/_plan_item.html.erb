<%= link_to curator_plan_path(plan), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm hover:shadow-lg transition-all overflow-hidden group" do %>
  <%# Header %>
  <div class="aspect-[4/3] overflow-hidden bg-gradient-to-br from-teal-500 to-emerald-600 flex items-center justify-center relative">
    <div class="text-center text-white">
      <svg class="w-16 h-16 mx-auto opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
      </svg>
      <p class="mt-2 text-lg font-medium opacity-90"><%= plan.calculated_duration_days %> <%= plan.calculated_duration_days == 1 ? 'dan' : 'dana' %></p>
    </div>
    <%# Visibility badge %>
    <div class="absolute top-2 left-2">
      <% if plan.visibility_public_plan? %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-white/90 dark:bg-gray-800/90 text-green-800 dark:text-green-300 backdrop-blur-sm">
          <%= t("curator.plans.public") %>
        </span>
      <% else %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-white/90 dark:bg-gray-800/90 text-gray-700 dark:text-gray-300 backdrop-blur-sm">
          <%= t("curator.plans.private") %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Content %>
  <div class="p-4">
    <h3 class="font-semibold text-gray-900 dark:text-white line-clamp-1 group-hover:text-emerald-600 transition-colors"><%= plan.title %></h3>

    <% if plan.city_name.present? %>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 flex items-center">
        <svg class="w-3.5 h-3.5 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        </svg>
        <span class="truncate"><%= plan.city_name %></span>
      </p>
    <% end %>

    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
      <%= plan.experiences.count %> <%= t("curator.plans.experiences").downcase %>
      <% if plan.user.present? %>
        &middot; <%= plan.user.username %>
      <% end %>
    </p>

    <%# Rating & date %>
    <div class="mt-3 flex items-center justify-between text-sm">
      <% if plan.average_rating.to_f > 0 %>
        <div class="flex items-center">
          <svg class="w-4 h-4 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
          </svg>
          <span class="font-medium text-gray-900 dark:text-white"><%= number_with_precision(plan.average_rating, precision: 1) %></span>
          <span class="text-gray-400 dark:text-gray-500 ml-1">(<%= plan.reviews_count %>)</span>
        </div>
      <% else %>
        <span class="text-gray-400 dark:text-gray-500"><%= t("explore.no_reviews", default: "Bez recenzija") %></span>
      <% end %>
      <span class="text-xs text-gray-400 dark:text-gray-500"><%= plan.created_at.strftime("%d.%m.%Y") %></span>
    </div>

    <%# Suggest changes %>
    <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
      <span class="flex items-center justify-center gap-2 py-1.5 text-sm font-medium text-emerald-600 dark:text-emerald-400 group-hover:text-emerald-800 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        <%= t("curator.suggest_changes", default: "Predloži izmjene") %>
      </span>
    </div>
  </div>
<% end %>
