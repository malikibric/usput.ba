<div class="space-y-4 sm:space-y-6">
  <%= render "curator/shared/pending_proposal_banner", pending_proposal: @pending_proposal %>

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= @plan.title %></h1>
    <div class="flex flex-col sm:flex-row gap-2">
      <%= link_to curator_plans_path,
          class: "inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-gray-800 dark:text-white dark:ring-gray-600 dark:hover:bg-gray-700" do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
        </svg>
        <%= t("curator.plans.back_to_list") %>
      <% end %>
      <%= link_to plan_path(@plan),
          class: "inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500" do %>
        <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.64 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.64 0-8.573-3.007-9.963-7.178z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <%= t("curator.plans.view_in_app", default: "View in App") %>
      <% end %>
      <% if Flipper.enabled?(:curator_edit_delete) %>
        <%= link_to edit_curator_plan_path(@plan),
            class: "inline-flex items-center justify-center rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500" do %>
          <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
          <%= t("curator.plans.edit", default: "Edit") %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg bg-white dark:bg-gray-800 shadow">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center gap-2 mb-4">
        <% if @plan.visibility_public_plan? %>
          <span class="inline-flex items-center rounded-full bg-green-100 dark:bg-green-900/30 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:text-green-300">
            <%= t("curator.plans.public") %>
          </span>
        <% else %>
          <span class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-2.5 py-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">
            <%= t("curator.plans.private") %>
          </span>
        <% end %>
        <% if @plan.reviews_count.to_i > 0 %>
          <span class="inline-flex items-center text-sm text-gray-500 dark:text-gray-400">
            <svg class="h-4 w-4 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <%= @plan.average_rating&.round(1) || 0 %> (<%= @plan.reviews_count %>)
          </span>
        <% end %>
      </div>

      <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.city") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.city_name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.author") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.user&.username || t("curator.plans.no_author") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.duration") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.duration_in_days %> <%= t("plans.day_plural") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.created_at") %></dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.created_at.strftime("%d.%m.%Y %H:%M") %></dd>
        </div>
        <% if @plan.start_date.present? && @plan.end_date.present? %>
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.dates") %></dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.start_date.strftime("%d.%m.%Y") %> - <%= @plan.end_date.strftime("%d.%m.%Y") %></dd>
          </div>
        <% end %>
        <% if @plan.notes.present? %>
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.notes") %></dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @plan.notes %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Experiences by Day -->
  <% if @plan.plan_experiences.any? %>
    <div class="rounded-lg bg-white dark:bg-gray-800 shadow">
      <div class="px-4 py-5 sm:px-6">
        <h2 class="text-lg font-medium text-gray-900 dark:text-white mb-4"><%= t("curator.plans.experiences") %></h2>

        <% (1..@plan.duration_in_days).each do |day_num| %>
          <% day_experiences = @plan.plan_experiences_for_day(day_num) %>
          <% if day_experiences.any? %>
            <div class="mb-4 last:mb-0">
              <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2"><%= t("plans.show.day", number: day_num) %></h3>
              <ul class="space-y-2">
                <% day_experiences.each do |pe| %>
                  <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <span class="w-6 h-6 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 flex items-center justify-center text-xs font-medium">
                      <%= pe.position %>
                    </span>
                    <%= link_to pe.experience.title, curator_experience_path(pe.experience), class: "text-emerald-600 dark:text-emerald-400 hover:text-emerald-900 dark:hover:text-emerald-300" %>
                    <span class="text-gray-400 dark:text-gray-500">(<%= pe.experience.locations.count %> <%= t("curator.plans.locations") %>)</span>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if Flipper.enabled?(:curator_edit_delete) %>
    <div class="flex gap-3">
      <%= link_to edit_curator_plan_path(@plan),
          class: "inline-flex items-center rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500" do %>
        <%= t("curator.plans.edit") %>
      <% end %>
      <%= button_to curator_plan_path(@plan),
          method: :delete,
          class: "inline-flex items-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500",
          data: { turbo_confirm: t("curator.plans.confirm_delete", title: @plan.title) } do %>
        <%= t("curator.plans.delete") %>
      <% end %>
    </div>
  <% end %>
</div>
