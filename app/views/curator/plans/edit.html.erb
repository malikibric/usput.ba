<div class="space-y-4 sm:space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.plans.edit_title", title: @plan.title) %></h1>
    <%= link_to t("curator.plans.back_to_view", default: "Back to View"), curator_plan_path(@plan), class: "text-sm text-emerald-600 hover:text-emerald-900 dark:hover:text-emerald-700" %>
  </div>

  <%= render "form", plan: @plan, city_names: @city_names, experience_types: @experience_types, experiences: @experiences %>
</div>
