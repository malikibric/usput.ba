<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-0">
    <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.plans.title") %></h1>
    <% if Flipper.enabled?(:curator_edit_delete) %>
      <%= link_to t("curator.plans.new"), new_curator_plan_path,
          class: "inline-flex items-center justify-center rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 w-full sm:w-auto" %>
    <% end %>
  </div>

  <!-- Pending Proposals -->
  <%= render "curator/shared/pending_proposals", pending_proposals: @pending_proposals %>

  <!-- Stats Overview -->
  <div class="grid grid-cols-2 gap-3 sm:gap-5 sm:grid-cols-4">
    <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 px-4 py-4 shadow">
      <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.total") %></dt>
      <dd class="mt-1 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white"><%= @stats[:total] %></dd>
    </div>
    <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 px-4 py-4 shadow">
      <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.public") %></dt>
      <dd class="mt-1 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white"><%= @stats[:public_plans] %></dd>
    </div>
    <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 px-4 py-4 shadow">
      <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.private") %></dt>
      <dd class="mt-1 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white"><%= @stats[:private_plans] %></dd>
    </div>
    <div class="overflow-hidden rounded-lg bg-white dark:bg-gray-800 px-4 py-4 shadow">
      <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400"><%= t("curator.plans.with_experiences") %></dt>
      <dd class="mt-1 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white"><%= @stats[:with_experiences] %></dd>
    </div>
  </div>

  <!-- Filters -->
  <div class="rounded-lg bg-white dark:bg-gray-800 shadow px-4 py-4">
    <%= form_with url: curator_plans_path, method: :get, class: "flex flex-col sm:flex-row flex-wrap gap-3" do |f| %>
      <div class="flex-1 min-w-0 sm:max-w-xs">
        <%= f.text_field :search,
            value: params[:search],
            placeholder: t("curator.plans.search_placeholder"),
            class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-sm shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div class="w-full sm:w-auto">
        <%= f.select :city_name,
            options_for_select([[t("curator.plans.all_cities"), ""]] + @city_names.map { |c| [c, c] }, params[:city_name]),
            {},
            class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-sm shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div class="w-full sm:w-auto">
        <%= f.select :visibility,
            options_for_select([
              [t("curator.plans.all_visibility"), ""],
              [t("curator.plans.public"), "public"],
              [t("curator.plans.private"), "private"]
            ], params[:visibility]),
            {},
            class: "block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white text-sm shadow-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div class="w-full sm:w-auto">
        <%= f.submit t("common.search"), class: "w-full sm:w-auto inline-flex justify-center items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <!-- Results Count -->
  <div class="text-sm text-gray-600 dark:text-gray-400">
    <span><%= t("curator.plans.count", count: @plans.total_count, default: "#{@plans.total_count} plans") %></span>
  </div>

  <!-- Load More Container -->
  <div data-controller="load-more"
       data-load-more-url-value="<%= curator_plans_path %>"
       data-load-more-resource-type-value="items"
       data-load-more-page-value="1"
       data-load-more-total-count-value="<%= @plans.total_count %>"
       data-load-more-per-page-value="3">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-load-more-target="container">
      <%= render "curator/plans/plan_items", plans: @plans %>
    </div>

    <% if @plans.empty? %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500 dark:text-gray-400">
        <%= t("curator.plans.no_plans") %>
      </div>
    <% end %>

    <!-- Load More Button -->
    <% if @plans.total_pages > 1 %>
      <div class="flex justify-center mt-6">
        <button type="button"
                data-load-more-target="button"
                data-action="click->load-more#loadMore"
                class="inline-flex items-center gap-2 rounded-lg bg-white dark:bg-gray-800 px-6 py-3 text-sm font-semibold text-gray-900 dark:text-white shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
          <%= t("common.load_more", default: "Load More") %>
        </button>

        <div class="hidden" data-load-more-target="loading">
          <div class="inline-flex items-center gap-2 px-6 py-3 text-sm text-gray-500">
            <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <%= t("common.loading", default: "Loading...") %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
