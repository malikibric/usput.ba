<div class="space-y-4 sm:space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white"><%= t("curator.locations.needs_photos.title") %></h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= t("curator.locations.needs_photos.description") %></p>
    </div>
    <%= link_to curator_locations_path, class: "text-sm text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 dark:hover:text-emerald-300" do %>
      &larr; <%= t("curator.locations.back_to_list") %>
    <% end %>
  </div>

  <%# Filters %>
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-4">
    <%= form_with url: needs_photos_curator_locations_path, method: :get, local: true, class: "flex flex-wrap gap-4 items-end" do %>
      <div class="flex-1 min-w-[200px]">
        <label for="city" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= t("curator.locations.city") %></label>
        <%= select_tag :city,
            options_for_select([["-- #{t('common.all')} --", ""]] + @city_names.map { |c| [c, c] }, params[:city]),
            class: "block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-emerald-600 sm:text-sm" %>
      </div>
      <div class="w-32">
        <label for="max_photos" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"><%= t("curator.locations.needs_photos.max_photos") %></label>
        <%= select_tag :max_photos,
            options_for_select([[t("common.all"), ""], ["0", 0], ["1", 1], ["2", 2], ["3", 3], ["5", 5]], params[:max_photos]),
            class: "block w-full rounded-md border-0 py-2 px-3 text-gray-900 dark:text-white dark:bg-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 focus:ring-2 focus:ring-emerald-600 sm:text-sm" %>
      </div>
      <div>
        <%= submit_tag t("common.filter"), class: "rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# Results %>
  <% if @locations.any? %>
    <div data-controller="load-more"
         data-load-more-url-value="<%= needs_photos_curator_locations_path %>"
         data-load-more-resource-type-value="items"
         data-load-more-page-value="1"
         data-load-more-total-count-value="<%= @locations.total_count %>"
         data-load-more-per-page-value="12">

      <div class="space-y-2" data-load-more-target="container">
        <%= render "curator/locations/needs_photo_items", locations: @locations %>
      </div>

      <%# Load More %>
      <div class="mt-6 text-center">
        <button type="button"
                class="hidden inline-flex items-center justify-center gap-2 rounded-md bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm ring-1 ring-inset ring-gray-300 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700"
                data-load-more-target="button"
                data-action="click->load-more#loadMore">
          <%= t("common.load_more", default: "Load More") %>
        </button>
        <div class="hidden" data-load-more-target="loading">
          <svg class="animate-spin h-5 w-5 text-emerald-600 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-semibold text-gray-900 dark:text-white"><%= t("curator.locations.needs_photos.no_results") %></h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= t("curator.locations.needs_photos.no_results_hint") %></p>
    </div>
  <% end %>
</div>
