<%= link_to curator_location_path(location), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm hover:shadow-lg transition-all overflow-hidden group" do %>
  <%# Image %>
  <div class="aspect-[4/3] overflow-hidden relative">
    <% if location.photos.attached? && location.photos.first.present? %>
      <% photo = location.photos.first %>
      <% if photo.variable? %>
        <%= image_tag photo.variant(resize_to_fill: [400, 300]),
            alt: location.name,
            loading: "lazy",
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
      <% else %>
        <%= image_tag photo,
            alt: location.name,
            loading: "lazy",
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
      <% end %>
    <% else %>
      <div class="w-full h-full bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center">
        <svg class="w-12 h-12 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        </svg>
      </div>
    <% end %>
    <%# Type badge %>
    <div class="absolute top-2 left-2">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-white/90 dark:bg-gray-800/90 text-gray-800 dark:text-gray-200 backdrop-blur-sm">
        <%= t("locations.types.#{location.category_key}", default: location.category_key&.humanize) %>
      </span>
    </div>
  </div>

  <%# Content %>
  <div class="p-4">
    <h3 class="font-semibold text-gray-900 dark:text-white line-clamp-1 group-hover:text-emerald-600 transition-colors"><%= location.name %></h3>

    <% if location.city.present? %>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 flex items-center">
        <svg class="w-3.5 h-3.5 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        </svg>
        <span class="truncate"><%= location.city %></span>
      </p>
    <% end %>

    <% if location.description.present? %>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2"><%= truncate(strip_tags(location.description), length: 100) %></p>
    <% end %>

    <%# Rating & date %>
    <div class="mt-3 flex items-center justify-between text-sm">
      <% if location.average_rating.to_f > 0 %>
        <div class="flex items-center">
          <svg class="w-4 h-4 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
          </svg>
          <span class="font-medium text-gray-900 dark:text-white"><%= number_with_precision(location.average_rating, precision: 1) %></span>
          <span class="text-gray-400 dark:text-gray-500 ml-1">(<%= location.reviews_count %>)</span>
        </div>
      <% else %>
        <span class="text-gray-400 dark:text-gray-500"><%= t("explore.no_reviews", default: "Bez recenzija") %></span>
      <% end %>
      <span class="text-xs text-gray-400 dark:text-gray-500"><%= location.created_at.strftime("%d.%m.%Y") %></span>
    </div>

    <%# Suggest changes %>
    <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-700">
      <span class="flex items-center justify-center gap-2 py-1.5 text-sm font-medium text-emerald-600 dark:text-emerald-400 group-hover:text-emerald-800 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
        <%= t("curator.suggest_changes", default: "Predloži izmjene") %>
      </span>
    </div>
  </div>
<% end %>
